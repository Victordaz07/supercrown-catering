# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Master User (used by seed script)
MASTER_EMAIL="admin@supercrown.com"
MASTER_PASSWORD="your-secure-password"
MASTER_NAME="Victor"

# Feature flags (migration guardrails)
# State Machine v2 — DEBE estar en true en producción
# Solo poner false para debugging del flujo legacy
FEATURE_ORDER_STATE_MACHINE_V2=true

# Quote lifecycle v2 — activar cuando QUOTE_V2 endpoints estén en uso
# (actualmente el flag no tiene ramas condicionadas — safe to enable)
FEATURE_QUOTE_V2=true

# Price lock — DEBE estar en true en producción
# Solo poner false para debugging
FEATURE_PRICE_LOCK=true

# Quote lifecycle
QUOTE_EXPIRY_DAYS=30
TAX_RATE=0.08

# Epic6: Adjustment governance
ADJUSTMENT_TIER_SMALL=50
ADJUSTMENT_TIER_MEDIUM=200
ADJUSTMENT_TIER_LARGE=500
ADJUSTMENT_AUTO_APPROVE_THRESHOLD=0

# Epic5: Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Epic4: Email
EMAIL_FROM=hello@supercrowncatering.com
EMAIL_FROM_QUOTES=quotes@supercrowncatering.com
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Cron security
CRON_SECRET=
